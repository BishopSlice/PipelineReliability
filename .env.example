# .env.example — copy to .env and fill in values

# ── Google AI (choose one backend) ────────────────────────────────────────────
# Option A: AI Studio (default — no GCP project required)
GOOGLE_API_KEY=your_ai_studio_key_here

# Option B: Vertex AI (set all three; comment out GOOGLE_API_KEY above)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# ── Fivetran credentials ───────────────────────────────────────────────────────
FIVETRAN_API_KEY=your_fivetran_api_key
FIVETRAN_API_SECRET=your_fivetran_api_secret

# ── Model selection (optional — these are the defaults) ───────────────────────
# ORCHESTRATOR_MODEL=gemini-3.1-flash-lite
# SUB_AGENT_MODEL=gemini-3.1-flash-lite

# ── HITL gate timeout (optional) ──────────────────────────────────────────────
# GATE_TIMEOUT_SECONDS=30

# ── Run timeout (optional) ────────────────────────────────────────────────────
# RUN_TIMEOUT_SECONDS=360

# D-47: Output token budget warning — warn when tokens_out exceeds this per run
# OUTPUT_TOKEN_BUDGET=8000

# D-48: Extra HTTP headers for Vertex AI inference (JSON object, optional)
# Example: {"X-Goog-User-Project": "my-project-id"}
# VERTEX_AI_EXTRA_HEADERS={}

# ── Fivetran connect card OAuth redirect (optional) ───────────────────────────
# For local demo: leave unset (defaults to http://localhost/fivetran-callback)
# For production: set to a live endpoint that completes the OAuth handshake
# CONNECT_CARD_REDIRECT_URI=https://your-domain.com/fivetran-callback

# ── Cloud Trace (optional — leave unset to disable) ───────────────────────────
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id   (same as Vertex AI project if using Vertex)
